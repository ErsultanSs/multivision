---
import Header from '../components/Header.astro';
import Hero from "../components/Hero.astro";
import QuickFacts from '../components/QuickFacts.astro';
import Partners from '../components/Partners.astro';
import AboutUs from "../components/AboutUs.astro";
import OurProducts from '../components/OurProducts.astro';
import EducationProgram from '../components/EducationProgram.astro';
import Portfolio from '../components/Portfolio.astro';
import WhyUs from "../components/WhyUs.astro";
import Contacts from "../components/Contacts.astro";
import Footer from '../components/Footer.astro';
import Layout from '../layouts/Layout.astro';

---
<Layout>
    <Header/>
    <Hero/>
    <QuickFacts/>
    <Partners/>
    <AboutUs/>
    <OurProducts/>
    <EducationProgram/>
    <Portfolio/>
    <WhyUs/>
    <Contacts/>
    <Footer/>
</Layout>

<script>
    import gsap from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    
    gsap.registerPlugin(ScrollTrigger);

    // Configure ScrollTrigger for better performance
    ScrollTrigger.config({
        limitCallbacks: true,
    });

    // About us cards animation
    const aboutCards = document.querySelectorAll('.about-card');
    aboutCards.forEach((card, index) => {
        gsap.fromTo(card,
            { opacity: 0, y: 60 },
            {
                opacity: 1, y: 0, duration: 0.8, ease: "power2.out",
                delay: index * 0.2,
                scrollTrigger: { trigger: card, start: "top 85%", once: true }
            }
        );
    });

    // Quick facts animation
    gsap.fromTo(".quick-facts",
        { opacity: 0, y: 50 },
        {
            opacity: 1, y: 0, duration: 1, ease: "power3.out",
            scrollTrigger: { trigger: ".quick-facts", start: "top 80%", once: true }
        }
    );

    // About us content
    gsap.fromTo(".about-us-content",
        { opacity: 0, y: 30 },
        {
            opacity: 1, y: 0, duration: 1, ease: "power3.out",
            scrollTrigger: { trigger: ".about-us-content", start: "top 80%", once: true }
        }
    );

    // Products header
    gsap.fromTo(".products-header",
        { opacity: 0, y: 50 },
        {
            opacity: 1, y: 0, duration: 1, ease: "power3.out",
            scrollTrigger: { trigger: ".products-header", start: "top 80%", once: true }
        }
    );

    // Product cards animation
    const productCards = document.querySelectorAll(".product-card");
    productCards.forEach((card, index) => {
        gsap.fromTo(card,
            { opacity: 0, y: 60, scale: 0.95 },
            {
                opacity: 1, y: 0, scale: 1, duration: 0.7, ease: "power2.out",
                delay: index * 0.15,
                scrollTrigger: { trigger: card, start: "top 85%", once: true }
            }
        );
    });

    // Education section animations
    gsap.fromTo(".education-content",
        { opacity: 0, y: 50 },
        {
            opacity: 1, y: 0, duration: 1, ease: "power3.out",
            scrollTrigger: { trigger: ".education-content", start: "top 80%", once: true }
        }
    );

    const educationCards = document.querySelectorAll(".education-card");
    educationCards.forEach((card, index) => {
        gsap.fromTo(card,
            { opacity: 0, y: 80, scale: 0.95 },
            {
                opacity: 1, y: 0, scale: 1, duration: 0.8, ease: "power2.out",
                delay: index * 0.2,
                scrollTrigger: { trigger: card, start: "top 85%", once: true }
            }
        );
    });

    // Stat cards
    const statCards = document.querySelectorAll(".stat-card");
    statCards.forEach((card, index) => {
        gsap.fromTo(card,
            { opacity: 0, y: 30, scale: 0.9 },
            {
                opacity: 1, y: 0, scale: 1, duration: 0.6, ease: "back.out(1.2)",
                delay: index * 0.1,
                scrollTrigger: { trigger: card, start: "top 90%", once: true }
            }
        );
    });

    // Education result
    gsap.fromTo(".education-result",
        { opacity: 0, y: 50 },
        {
            opacity: 1, y: 0, duration: 1, ease: "power3.out",
            scrollTrigger: { trigger: ".education-result", start: "top 80%", once: true }
        }
    );

    // Case study slider
    gsap.fromTo(".case-study-slider",
        { opacity: 0, y: 40 },
        {
            opacity: 1, y: 0, duration: 1, ease: "power2.out",
            scrollTrigger: { trigger: ".case-study-slider", start: "top 80%", once: true }
        }
    );

    // Why Us title
    gsap.fromTo(".why-us-title",
        { opacity: 0, y: 30 },
        {
            opacity: 1, y: 0, duration: 1, ease: "power2.out",
            scrollTrigger: { trigger: ".why-us-title", start: "top 85%", once: true }
        }
    );

    // Industry cards animation
    const industryCards = document.querySelectorAll(".industry-card");
    industryCards.forEach((card, index) => {
        gsap.fromTo(card,
            { opacity: 0, y: 40, scale: 0.95 },
            {
                opacity: 1, y: 0, scale: 1, duration: 0.6, ease: "power2.out",
                delay: index * 0.1,
                scrollTrigger: { trigger: card, start: "top 85%", once: true }
            }
        );
    });

    // Contact section
    gsap.fromTo(".contact-section",
        { opacity: 0, y: 50 },
        {
            opacity: 1, y: 0, duration: 1, ease: "power3.out",
            scrollTrigger: { trigger: ".contact-section", start: "top 80%", once: true }
        }
    );

    // Fact items stagger
    const factItems = document.querySelectorAll(".fact-item");
    factItems.forEach((item, index) => {
        gsap.fromTo(item,
            { opacity: 0, x: 30 },
            {
                opacity: 1, x: 0, duration: 0.6, ease: "power2.out",
                delay: index * 0.2,
                scrollTrigger: { trigger: item, start: "top 90%", once: true }
            }
        );
    });
</script>