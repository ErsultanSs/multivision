---
import Header from '../../components/Header.astro';
import Layout from '../../layouts/Layout.astro';
import Contacts from '../../components/Contacts.astro';
import heroBackground from '../../assets/hero-bg.jpg';

const pageTitle = 'Редакционно-издательская система (РИС) | Multivision';
const pageDescription =
	'Редакционно-издательская система, полностью внедрённая и эксплуатируемая 24/7, покрывает весь цикл работы редакции и масштабируется для команд из 100+ пользователей.';
const pageOgDescription =
	'Успешно внедрённая РИС: веб-архитектура, workflow, совместное редактирование, аналитика и экспорт в профессиональные форматы.';
const heroImage = heroBackground.src;
---

<Layout
	title={pageTitle}
	description={pageDescription}
	ogTitle={pageTitle}
	ogDescription={pageOgDescription}
	ogImage={heroImage}
>
	<section
		class="flex flex-col bg-gradient-to-br from-blue-50/50 via-white to-purple-50/50 min-h-[620px] px-[10px] lg:px-12 py-[22px] lg:py-[34px]"
	>
		<Header />
		<div class="flex-1 flex items-center">
			<div class="max-w-4xl">
				<p class="uppercase text-xs tracking-[0.35em] text-gray-600 mb-6">Решение · в эксплуатации с 2023 года</p>
				<h1 class="text-[46px] sm:text-[60px] lg:text-[82px] font-bold leading-[0.85] tracking-[-0.04em] mb-8 text-gray-900">
					Редакционно-издательская система (РИС)
				</h1>
				<p class="text-[18px] sm:text-[22px] text-gray-700 leading-relaxed max-w-2xl mb-10">
					Проект успешно внедрён и стабильно работает у заказчика: непрерывное управление контентом, версткой и командами в единой системе.
				</p>
				<div class="flex flex-col sm:flex-row gap-4">
					<a
						href="#contacts"
						class="inline-flex items-center justify-center bg-gradient-to-r from-[#0052CC] to-[#4C9AFF] text-white px-8 py-4 rounded-lg font-semibold text-base shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
					>
						Связаться с нами
					</a>
				</div>
			</div>
		</div>
	</section>

	<section class="max-w-[1440px] mx-auto px-[10px] lg:px-12 py-[70px] lg:py-[120px] space-y-16 bg-white">
		<div class="grid gap-8 lg:gap-12 lg:grid-cols-[1.1fr,0.9fr] bg-gradient-to-r from-gray-50 to-blue-50/30 rounded-3xl p-8 lg:p-14 border-2 border-gray-200 shadow-md">
			<div class="space-y-6">
				<h2 class="text-[32px] sm:text-[42px] lg:text-[48px] font-bold leading-tight tracking-[-0.04em] text-gray-900">
					Описание проекта
				</h2>
				<p class="text-gray-700 text-[18px] leading-[1.65]">
					РИС полностью соответствует технической спецификации: платформа охватывает весь редакционный цикл — от планирования выпусков и сбора материалов до верстки, согласования и подготовки файлов для печати или digital-каналов. Все роли редакции работают в единой среде.
				</p>
				<p class="text-gray-700 text-[18px] leading-[1.65]">
					Решение развёрнуто на инфраструктуре заказчика, поддерживает требования по безопасности и гарантирует автономность. Масштабируемая архитектура рассчитана на 100+ одновременно работающих пользователей, включая распределённые редакции и удалённые команды.
				</p>
				<p class="text-gray-700 text-[18px] leading-[1.65]">
					Платформа обеспечивает хранение версий материалов и выпусков, отслеживание статусов в реальном времени и автоматизацию контроля дедлайнов. Интеграции и API подтверждают непрерывность процесса 24/7 и соответствие договорным SLA.
				</p>
			</div>
			<div class="bg-white border-2 border-gray-200 rounded-3xl p-8 space-y-6 shadow-md">
				<h3 class="text-[24px] lg:text-[28px] font-semibold text-gray-900">Ключевые характеристики</h3>
				<ul class="space-y-4 text-gray-700 text-[16px] leading-[1.6]">
					<li class="flex items-start gap-3">
						<svg class="w-6 h-6 text-[#0052CC] flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
							<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
						</svg>
						<span>Веб-интерфейс с безопасным доступом через браузер</span>
					</li>
					<li class="flex items-start gap-3">
						<svg class="w-6 h-6 text-[#0052CC] flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
							<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
						</svg>
						<span>Версионность материалов, макетов и полос</span>
					</li>
					<li class="flex items-start gap-3">
						<svg class="w-6 h-6 text-[#0052CC] flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
							<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
						</svg>
						<span>Высокая готовность для интеграций, выгрузок и миграции данных</span>
					</li>
					<li class="flex items-start gap-3">
						<svg class="w-6 h-6 text-[#0052CC] flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
							<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
						</svg>
						<span>Гибкая настройка ролей и прав доступа</span>
					</li>
				</ul>
			</div>
		</div>

		<div class="bg-gradient-to-br from-blue-50/50 to-purple-50/50 rounded-3xl p-8 lg:p-14 border-2 border-gray-200">
			<div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-12">
				<div class="max-w-xl">
					<h2 class="text-[32px] sm:text-[42px] lg:text-[48px] font-bold leading-tight tracking-[-0.04em] mb-8 text-gray-900">
						Ключевые преимущества
					</h2>
					<p class="text-gray-700 text-[18px] leading-[1.65]">
						Мы объединили современную веб-архитектуру и требования редакций к надёжности, интеграциям и круглосуточной эксплуатации.
					</p>
				</div>
				<ul class="grid gap-6 sm:grid-cols-2 text-gray-700 text-[16px] leading-[1.65]">
					<li class="bg-white border-2 border-gray-200 rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow">Веб-архитектура: React, Django, PostgreSQL</li>
					<li class="bg-white border-2 border-gray-200 rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow">Работа 24/7 и мониторинг надежности</li>
					<li class="bg-white border-2 border-gray-200 rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow">Настраиваемые workflow и автоматизация статусов</li>
					<li class="bg-white border-2 border-gray-200 rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow">Совместное редактирование в реальном времени</li>
					<li class="bg-white border-2 border-gray-200 rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow">Drag-and-drop верстальщик полос и шаблонов</li>
					<li class="bg-white border-2 border-gray-200 rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow">Встроенная медиабиблиотека с поиском и версиями</li>
					<li class="bg-white border-2 border-gray-200 rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow">Отчётность, аналитика и контроль SLA</li>
					<li class="bg-white border-2 border-gray-200 rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow">Экспорт в IDML, XML, DOCX, PDF</li>
					<li class="bg-white border-2 border-gray-200 rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow">Webhooks и API для интеграции с внешними сервисами</li>
				</ul>
			</div>
		</div>

		<div class="grid gap-10 lg:grid-cols-2">
			<div class="bg-white border-2 border-gray-200 rounded-3xl p-8 lg:p-12 shadow-md">
				<h2 class="text-[28px] sm:text-[36px] font-bold tracking-[-0.04em] mb-6 text-gray-900">
					Что реализовано полностью
				</h2>
				<ul class="space-y-4 text-gray-700 text-[16px] leading-[1.65]">
					<li class="flex items-start gap-3">
						<svg class="w-6 h-6 text-green-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
							<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
						</svg>
						<span>Единое планирование выпусков, статей и полос с контрольными точками.</span>
					</li>
					<li class="flex items-start gap-3">
						<svg class="w-6 h-6 text-green-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
							<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
						</svg>
						<span>Маршрутизация заданий, статусы и оповещения для всех ролей редакции.</span>
					</li>
					<li class="flex items-start gap-3">
						<svg class="w-6 h-6 text-green-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
							<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
						</svg>
						<span>Версионность материалов, макетов и медиаконтента с восстановлением истории.</span>
					</li>
					<li class="flex items-start gap-3">
						<svg class="w-6 h-6 text-green-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
							<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
						</svg>
						<span>Совместное редактирование, блокировки и комментарии в реальном времени.</span>
					</li>
					<li class="flex items-start gap-3">
						<svg class="w-6 h-6 text-green-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
							<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
						</svg>
						<span>Интерфейсы для редактора, журналиста, корректора и верстальщика в одном пространстве.</span>
					</li>
					<li class="flex items-start gap-3">
						<svg class="w-6 h-6 text-green-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
							<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
						</svg>
						<span>Автоматические отчёты и дашборды по статусу материалов и соблюдению сроков.</span>
					</li>
				</ul>
			</div>
			<div class="bg-white border-2 border-gray-200 rounded-3xl p-8 lg:p-12 shadow-md">
				<h2 class="text-[28px] sm:text-[36px] font-bold tracking-[-0.04em] mb-6 text-gray-900">
					Современный веб-интерфейс и Adobe-интеграции
				</h2>
				<p class="text-gray-700 text-[16px] leading-[1.7] mb-6">
					Проект реализован без компромиссов: редакторы и верстальщики работают в современном веб-интерфейсе, сохраняя совместимость с процессами Adobe и форматами, описанными в технической спецификации.
				</p>
				<ul class="space-y-4 text-gray-700 text-[16px] leading-[1.65]">
					<li class="flex items-start gap-3">
						<span class="text-[#0052CC] font-bold mt-0.5">•</span>
						<span>Редактирование макетов, текстов и медиаматериалов в браузере с контролем версий.</span>
					</li>
					<li class="flex items-start gap-3">
						<span class="text-[#0052CC] font-bold mt-0.5">•</span>
						<span>Экспорт и импорт в IDML, XML, DOCX и PDF для бесшовной работы с Adobe InDesign/InCopy.</span>
					</li>
					<li class="flex items-start gap-3">
						<span class="text-[#0052CC] font-bold mt-0.5">•</span>
						<span>Webhooks и API для обмена данными с корпоративными системами и автоматизации процессов.</span>
					</li>
					<li class="flex items-start gap-3">
						<span class="text-[#0052CC] font-bold mt-0.5">•</span>
						<span>Централизованное управление учётными записями, правами и лицензиями внутри РИС.</span>
					</li>
				</ul>
			</div>
		</div>

		<div class="bg-gradient-to-r from-blue-50 to-purple-50 rounded-3xl p-8 lg:p-14 border-2 border-gray-200">
			<div class="max-w-4xl space-y-6">
				<h2 class="text-[32px] sm:text-[42px] lg:text-[48px] font-bold leading-tight tracking-[-0.04em] text-gray-900">
					Результат
				</h2>
				<p class="text-gray-700 text-[18px] leading-[1.65]">
					Проект прошёл полный цикл внедрения — от обследования до опытной эксплуатации — и несколько редакционных сезонов функционирует без перебоев. Все требования технической спецификации закрыты: функционал реализован полностью, подтверждён опытной эксплуатацией и готов к дальнейшему масштабированию.
				</p>
				<ul class="grid gap-4 sm:grid-cols-2 text-gray-700 text-[16px] leading-[1.7]">
					<li class="bg-white border-2 border-gray-200 rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow">
						Полное покрытие требований и ролей: редактор, журналист, корректор, верстальщик, администратор.
					</li>
					<li class="bg-white border-2 border-gray-200 rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow">
						Круглосуточная работа 24/7 с контролем версий, дедлайнов и уведомлений.
					</li>
					<li class="bg-white border-2 border-gray-200 rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow">
						Готовая инфраструктура для интеграций и миграции данных, соответствующая ТЗ.
					</li>
					<li class="bg-white border-2 border-gray-200 rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow">
						Информационная безопасность: локальное развёртывание, управление доступами, резервирование данных.
					</li>
				</ul>
			</div>
		</div>

		<div class="bg-gradient-to-br from-gray-50 to-blue-50/30 rounded-3xl p-8 lg:p-14 text-center border-2 border-gray-200 shadow-md">
			<h2 class="text-[32px] sm:text-[42px] lg:text-[48px] font-bold leading-tight tracking-[-0.04em] mb-6 text-gray-900">
				Хотите аналогичный проект?
			</h2>
			<p class="text-gray-700 text-[18px] leading-[1.7] max-w-3xl mx-auto mb-10">
				Оставьте заявку — мы адаптируем редакционно-издательскую систему под ваши процессы и интегрируем её с существующими инструментами.
			</p>
			<a
				href="#contacts"
				class="inline-flex items-center justify-center bg-gradient-to-r from-[#0052CC] to-[#4C9AFF] text-white px-8 py-4 rounded-lg font-semibold text-base shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
			>
				Оставить заявку
			</a>
		</div>
	</section>

	<Contacts />
</Layout>
