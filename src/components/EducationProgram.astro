---
import Title from "./Title.astro";
import Subtitle from "./Subtitle.astro";
import { Image } from "astro:assets";
---

<div id="products" class="max-w-[1440px] 2xl:max-w-[1700px] mx-auto flex flex-col gap-8 sm:gap-16 px-[10px] lg:px-12 2xl:px-20 py-[56px] lg:py-[84px] bg-gray-50">

    <!-- AI Education Courses - Main Focus -->
    <div class="pl-0 md:pl-16 mx-auto max-w-4xl products-header text-center">
        <Title class="text-white">ИИ-Образование: Будущее начинается здесь</Title>
        <Subtitle>
            Откройте двери в мир искусственного интеллекта вместе с нами! Наши инновационные курсы используют передовые AI-технологии для персонализированного обучения. Мы не просто учим программированию - мы формируем новое поколение ИИ-инноваторов, которые будут создавать будущее Казахстана. Если вы только заканчиваете школу - наша программа лучший выбор для раскрытия таланта на раннем этапе. Присоединяйтесь к революции в образовании!
        </Subtitle>
    </div>
    
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
        <!-- Main Program Description -->
        <div class="education-card bg-white p-8 md:p-10 rounded-2xl border-2 border-gray-200 shadow-md hover:shadow-xl hover:border-blue-500 transition-all duration-300">
            <div class="mb-6">
                <h3 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">
                    О программе
                </h3>
                <div class="h-1 w-20 bg-gradient-to-r from-[#0052CC] to-[#4C9AFF] rounded-full"></div>
            </div>
            
            <div class="space-y-4 text-base md:text-lg text-gray-700 leading-relaxed">
                <p>
                    Проект объединяет обучение практическим навыкам в сфере IT, искусственного интеллекта, 
                    веб-разработки с созданием реальных работающих продуктов и их коммерциализацией.
                </p>
                <p class="pt-2">
                    Курс включает теоретические и практические занятия по веб-разработке (frontend/backend), 
                    искусственному интеллекту, маркетингу, дизайну, выходу на рынок и созданию MVP.
                </p>
            </div>
        </div>

        <!-- Key Goals -->
        <div class="education-card bg-white p-8 md:p-10 rounded-2xl border-2 border-gray-200 shadow-md hover:shadow-xl hover:border-green-600 transition-all duration-300">
            <div class="mb-6">
                <h3 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">
                    Основные задачи
                </h3>
                <div class="h-1 w-20 bg-gradient-to-r from-green-600 to-[#00B8D9] rounded-full"></div>
            </div>
            
            <ul class="space-y-4">
                <li class="flex gap-3 items-start">
                    <svg class="w-6 h-6 text-green-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                    <span class="text-base md:text-lg text-gray-700">
                        Обучение созданию конкурентоспособных продуктов с использованием ИИ
                    </span>
                </li>
                <li class="flex gap-3 items-start">
                    <svg class="w-6 h-6 text-blue-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                    <span class="text-base md:text-lg text-gray-700">
                        Формирование компетенций в сфере ИИ и информационных технологий
                    </span>
                </li>
                <li class="flex gap-3 items-start">
                    <svg class="w-6 h-6 text-purple-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                    <span class="text-base md:text-lg text-gray-700">
                        Создание активного IT-сообщества в Алматы
                    </span>
                </li>
                <li class="flex gap-3 items-start">
                    <svg class="w-6 h-6 text-pink-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                    </svg>
                    <span class="text-base md:text-lg text-gray-700">
                        Развитие молодежного технологического предпринимательства
                    </span>
                </li>
            </ul>
        </div>
    </div>

    <!-- Statistics Grid -->
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mt-8">
        <div class="stat-card bg-white p-6 rounded-xl border-2 border-gray-200 text-center hover:border-blue-500 hover:shadow-lg transition-all duration-300">
            <div class="text-3xl md:text-5xl font-bold bg-gradient-to-r from-[#0052CC] to-[#4C9AFF] bg-clip-text text-transparent">
                10K
            </div>
            <div class="text-xs md:text-sm text-gray-600 mt-2 font-medium">
                учащихся на этапе отбора
            </div>
        </div>

        <div class="stat-card bg-white p-6 rounded-xl border-2 border-gray-200 text-center hover:border-purple-600 hover:shadow-lg transition-all duration-300">
            <div class="text-3xl md:text-5xl font-bold bg-gradient-to-r from-purple-600 to-purple-800 bg-clip-text text-transparent">
                1K
            </div>
            <div class="text-xs md:text-sm text-gray-600 mt-2 font-medium">
                участников в программе
            </div>
        </div>

        <div class="stat-card bg-white p-6 rounded-xl border-2 border-gray-200 text-center hover:border-green-600 hover:shadow-lg transition-all duration-300">
            <div class="text-3xl md:text-5xl font-bold bg-gradient-to-r from-green-600 to-green-800 bg-clip-text text-transparent">
                1K+
            </div>
            <div class="text-xs md:text-sm text-gray-600 mt-2 font-medium">
                веб-приложений с ИИ
            </div>
        </div>

        <div class="stat-card bg-white p-6 rounded-xl border-2 border-gray-200 text-center hover:border-yellow-600 hover:shadow-lg transition-all duration-300">
            <div class="text-3xl md:text-5xl font-bold bg-gradient-to-r from-yellow-600 to-orange-600 bg-clip-text text-transparent">
                3
            </div>
            <div class="text-xs md:text-sm text-gray-600 mt-2 font-medium">
                хакатона по 24 часа
            </div>
        </div>

        <div class="stat-card bg-white p-6 rounded-xl border-2 border-gray-200 text-center hover:border-pink-600 hover:shadow-lg transition-all duration-300">
            <div class="text-3xl md:text-5xl font-bold bg-gradient-to-r from-pink-600 to-rose-600 bg-clip-text text-transparent">
                TOP 10
            </div>
            <div class="text-xs md:text-sm text-gray-600 mt-2 font-medium">
                проектов на демо-дне
            </div>
        </div>

        <div class="stat-card bg-white p-6 rounded-xl border-2 border-gray-200 text-center hover:border-red-600 hover:shadow-lg transition-all duration-300">
            <div class="text-3xl md:text-5xl font-bold bg-gradient-to-r from-red-600 to-red-800 bg-clip-text text-transparent">
                USA
            </div>
            <div class="text-xs md:text-sm text-gray-600 mt-2 font-medium">
                поездка в Кремниевую долину
            </div>
        </div>
    </div>



<style>
    .education-card {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .education-card:hover {
        transform: translateY(-4px);
    }

    .stat-card {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .stat-card:hover {
        transform: translateY(-4px) scale(1.02);
    }
</style>

