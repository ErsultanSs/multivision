---
import { Image } from "astro:assets";
import heroBg from "../assets/hero-bg.jpg";
---

<div id="home" class="relative w-full overflow-hidden" style="margin-top: 80px;">
    <!-- Slider container -->
    <div class="hero-slider relative min-h-[600px] md:min-h-[700px] lg:min-h-[786px]">
        <!-- Slide 1 -->
        <div class="hero-slide absolute inset-0 flex items-center justify-center opacity-100 transition-opacity duration-700">
            <div class="absolute inset-0 bg-gradient-to-br from-[#003D99] via-[#0052CC] to-[#003D99]"></div>
            <div class="absolute inset-0 bg-black/30"></div>
            <div class="relative z-10 text-center max-w-4xl mx-auto px-6">
                <div class="mb-6">
                    <Image src={heroBg} alt="" class="hidden" />
                </div>
                <h1 class="hero-heading text-white text-[32px] sm:text-[48px] md:text-[56px] lg:text-[68px] font-bold leading-tight mb-6">
                    Воплощаем идеи,<br/>создавая решения
                </h1>
                <p class="hero-subheading text-white/85 text-lg md:text-xl lg:text-2xl leading-relaxed mb-10 max-w-2xl mx-auto">
                    Инновационная IT-компания с 10+ летним опытом. Цифровые решения для корпоративных и государственных клиентов.
                </p>
                <div class="hero-cta">
                    <a href="#contacts" class="inline-block px-10 py-4 border-2 border-white text-white font-semibold text-base rounded-md hover:bg-white hover:text-[#0052CC] transition-all duration-300">
                        Начать проект
                    </a>
                </div>
            </div>
        </div>

        <!-- Slide 2 -->
        <div class="hero-slide absolute inset-0 flex items-center justify-center opacity-0 transition-opacity duration-700">
            <div class="absolute inset-0 bg-gradient-to-br from-[#5243AA] via-[#003D99] to-[#0052CC]"></div>
            <div class="absolute inset-0 bg-black/30"></div>
            <div class="relative z-10 text-center max-w-4xl mx-auto px-6">
                <h1 class="hero-heading text-white text-[32px] sm:text-[48px] md:text-[56px] lg:text-[68px] font-bold leading-tight mb-6">
                    Лучшие решения<br/>для вашего проекта
                </h1>
                <p class="hero-subheading text-white/85 text-lg md:text-xl lg:text-2xl leading-relaxed mb-10 max-w-2xl mx-auto">
                    AI-технологии, VR/AR разработка, мобильные и веб-приложения мирового качества. 
                </p>
                <div class="hero-cta">
                    <a href="#portfolio" class="inline-block px-10 py-4 border-2 border-white text-white font-semibold text-base rounded-md hover:bg-white hover:text-[#5243AA] transition-all duration-300">
                        Наши проекты
                    </a>
                </div>
            </div>
        </div>

        <!-- Slide 3 -->
        <div class="hero-slide absolute inset-0 flex items-center justify-center opacity-0 transition-opacity duration-700">
            <div class="absolute inset-0 bg-gradient-to-br from-[#0052CC] via-[#00B8D9] to-[#003D99]"></div>
            <div class="absolute inset-0 bg-black/30"></div>
            <div class="relative z-10 text-center max-w-4xl mx-auto px-6">
                <h1 class="hero-heading text-white text-[32px] sm:text-[48px] md:text-[56px] lg:text-[68px] font-bold leading-tight mb-6">
                    Масштабируем IT-решения<br/>для будущего
                </h1>
                <p class="hero-subheading text-white/85 text-lg md:text-xl lg:text-2xl leading-relaxed mb-10 max-w-2xl mx-auto">
                    Государственные контракты, корпоративные решения и образовательные AI-программы.
                </p>
                <div class="hero-cta">
                    <a href="#products" class="inline-block px-10 py-4 border-2 border-white text-white font-semibold text-base rounded-md hover:bg-white hover:text-[#00B8D9] transition-all duration-300">
                        Узнать больше
                    </a>
                </div>
            </div>
        </div>

        <!-- Slider arrows -->
        <button class="hero-arrow hero-arrow-left absolute left-4 md:left-8 top-1/2 -translate-y-1/2 z-20 w-12 h-12 flex items-center justify-center rounded-full bg-white/20 hover:bg-white/40 backdrop-blur-sm text-white transition-all duration-300" aria-label="Предыдущий слайд">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <button class="hero-arrow hero-arrow-right absolute right-4 md:right-8 top-1/2 -translate-y-1/2 z-20 w-12 h-12 flex items-center justify-center rounded-full bg-white/20 hover:bg-white/40 backdrop-blur-sm text-white transition-all duration-300" aria-label="Следующий слайд">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </button>

        <!-- Slider dots -->
        <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 flex gap-3">
            <button class="hero-dot w-3 h-3 rounded-full bg-white transition-all duration-300 opacity-100" data-slide="0" aria-label="Слайд 1"></button>
            <button class="hero-dot w-3 h-3 rounded-full bg-white/50 transition-all duration-300" data-slide="1" aria-label="Слайд 2"></button>
            <button class="hero-dot w-3 h-3 rounded-full bg-white/50 transition-all duration-300" data-slide="2" aria-label="Слайд 3"></button>
        </div>
    </div>
</div>

<script>
    import gsap from "gsap";

    const slides = document.querySelectorAll('.hero-slide');
    const dots = document.querySelectorAll('.hero-dot');
    const arrowLeft = document.querySelector('.hero-arrow-left');
    const arrowRight = document.querySelector('.hero-arrow-right');
    let currentSlide = 0;
    let autoplayInterval: ReturnType<typeof setInterval>;

    function goToSlide(index: number) {
        // Fade out current
        slides[currentSlide]?.classList.remove('opacity-100');
        slides[currentSlide]?.classList.add('opacity-0');
        dots[currentSlide]?.classList.remove('opacity-100');
        dots[currentSlide]?.classList.add('opacity-50');

        currentSlide = (index + slides.length) % slides.length;

        // Fade in next
        slides[currentSlide]?.classList.remove('opacity-0');
        slides[currentSlide]?.classList.add('opacity-100');
        dots[currentSlide]?.classList.remove('opacity-50');
        dots[currentSlide]?.classList.add('opacity-100');

        // Animate content
        const heading = slides[currentSlide]?.querySelector('.hero-heading');
        const sub = slides[currentSlide]?.querySelector('.hero-subheading');
        const cta = slides[currentSlide]?.querySelector('.hero-cta');
        
        gsap.fromTo(heading, { y: 30, opacity: 0 }, { y: 0, opacity: 1, duration: 0.8, ease: "power2.out" });
        gsap.fromTo(sub, { y: 20, opacity: 0 }, { y: 0, opacity: 1, duration: 0.8, delay: 0.2, ease: "power2.out" });
        gsap.fromTo(cta, { y: 20, opacity: 0 }, { y: 0, opacity: 1, duration: 0.8, delay: 0.4, ease: "power2.out" });
    }

    function startAutoplay() {
        autoplayInterval = setInterval(() => goToSlide(currentSlide + 1), 5000);
    }

    function resetAutoplay() {
        clearInterval(autoplayInterval);
        startAutoplay();
    }

    arrowLeft?.addEventListener('click', () => { goToSlide(currentSlide - 1); resetAutoplay(); });
    arrowRight?.addEventListener('click', () => { goToSlide(currentSlide + 1); resetAutoplay(); });
    
    dots.forEach((dot, i) => {
        dot.addEventListener('click', () => { goToSlide(i); resetAutoplay(); });
    });

    // Initial animation for first slide
    const firstHeading = slides[0]?.querySelector('.hero-heading');
    const firstSub = slides[0]?.querySelector('.hero-subheading');
    const firstCta = slides[0]?.querySelector('.hero-cta');
    gsap.fromTo(firstHeading, { y: 40, opacity: 0 }, { y: 0, opacity: 1, duration: 1, delay: 0.3, ease: "power2.out" });
    gsap.fromTo(firstSub, { y: 30, opacity: 0 }, { y: 0, opacity: 1, duration: 1, delay: 0.6, ease: "power2.out" });
    gsap.fromTo(firstCta, { y: 20, opacity: 0 }, { y: 0, opacity: 1, duration: 1, delay: 0.9, ease: "power2.out" });

    startAutoplay();
</script>

<style>
    .hero-slide {
        z-index: 1;
    }
    .hero-slide.opacity-100 {
        z-index: 5;
    }
    @media (min-width: 1024px) {
        .hero-slider {
            margin-top: 10px;
        }
    }
</style>