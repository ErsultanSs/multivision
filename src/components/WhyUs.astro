---
---
<section id="whyus" class="py-16 md:py-24 bg-white">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-8">
        <!-- Section header -->
        <div class="text-center mb-12 md:mb-16">
            <h2 class="why-us-title text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-gray-900 leading-tight mb-4">
                Почему выбирают нас?
            </h2>
            <p class="text-base md:text-lg text-gray-600 max-w-2xl mx-auto">
                Экспертиза в ключевых направлениях IT, подкрепленная 10+ годами успешного опыта
            </p>
        </div>

        <!-- Industry/capability grid (3 cols x 2 rows) -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            <!-- Card 1: AI -->
            <div class="industry-card group relative h-[240px] md:h-[280px] rounded-xl overflow-hidden cursor-pointer">
                <img src="/services/ai.jpg" alt="AI" class="absolute inset-0 w-full h-full object-cover"/>
                <div class="absolute inset-0 bg-[#0052CC]/70 group-hover:bg-[#0052CC]/55 transition-all duration-300"></div>
                <div class="relative z-10 flex flex-col justify-end h-full p-6 md:p-8">
                    <div class="mb-3">
                        <svg class="w-10 h-10 text-white/80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                    </div>
                    <h3 class="text-xl md:text-2xl font-bold text-white">Искусственный интеллект</h3>
                    <p class="text-white/70 text-sm mt-2 group-hover:text-white/90 transition-colors">AI-решения, машинное обучение, NLP</p>
                </div>
            </div>

            <!-- Card 2: VR/AR -->
            <div class="industry-card group relative h-[240px] md:h-[280px] rounded-xl overflow-hidden cursor-pointer">
                <img src="/services/vr-ar.jpg" alt="VR AR" class="absolute inset-0 w-full h-full object-cover"/>
                <div class="absolute inset-0 bg-[#5243AA]/70 group-hover:bg-[#5243AA]/55 transition-all duration-300"></div>
                <div class="relative z-10 flex flex-col justify-end h-full p-6 md:p-8">
                    <div class="mb-3">
                        <svg class="w-10 h-10 text-white/80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                    </div>
                    <h3 class="text-xl md:text-2xl font-bold text-white">VR & AR Технологии</h3>
                    <p class="text-white/70 text-sm mt-2 group-hover:text-white/90 transition-colors">Виртуальная и дополненная реальность</p>
                </div>
            </div>

            <!-- Card 3: Education -->
            <div class="industry-card group relative h-[240px] md:h-[280px] rounded-xl overflow-hidden cursor-pointer">
                <img src="/services/education.jpg" alt="Образование" class="absolute inset-0 w-full h-full object-cover"/>
                <div class="absolute inset-0 bg-[#00875A]/70 group-hover:bg-[#00875A]/55 transition-all duration-300"></div>
                <div class="relative z-10 flex flex-col justify-end h-full p-6 md:p-8">
                    <div class="mb-3">
                        <svg class="w-10 h-10 text-white/80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                    </div>
                    <h3 class="text-xl md:text-2xl font-bold text-white">Образование</h3>
                    <p class="text-white/70 text-sm mt-2 group-hover:text-white/90 transition-colors">AI-курсы, EdTech платформы</p>
                </div>
            </div>

            <!-- Card 4: Government -->
            <div class="industry-card group relative h-[240px] md:h-[280px] rounded-xl overflow-hidden cursor-pointer">
                <img src="/services/gov.jpg" alt="Госсектор" class="absolute inset-0 w-full h-full object-cover"/>
                <div class="absolute inset-0 bg-[#003D99]/70 group-hover:bg-[#003D99]/55 transition-all duration-300"></div>
                <div class="relative z-10 flex flex-col justify-end h-full p-6 md:p-8">
                    <div class="mb-3">
                        <svg class="w-10 h-10 text-white/80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                    </div>
                    <h3 class="text-xl md:text-2xl font-bold text-white">Госсектор</h3>
                    <p class="text-white/70 text-sm mt-2 group-hover:text-white/90 transition-colors">Государственные контракты и решения</p>
                </div>
            </div>

            <!-- Card 5: Emergency -->
            <div class="industry-card group relative h-[240px] md:h-[280px] rounded-xl overflow-hidden cursor-pointer">
                <img src="/services/security.jpg" alt="Безопасность" class="absolute inset-0 w-full h-full object-cover"/>
                <div class="absolute inset-0 bg-[#DC2626]/70 group-hover:bg-[#DC2626]/55 transition-all duration-300"></div>
                <div class="relative z-10 flex flex-col justify-end h-full p-6 md:p-8">
                    <div class="mb-3">
                        <svg class="w-10 h-10 text-white/80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                    </div>
                    <h3 class="text-xl md:text-2xl font-bold text-white">Безопасность</h3>
                    <p class="text-white/70 text-sm mt-2 group-hover:text-white/90 transition-colors">Системы оповещения и реагирования</p>
                </div>
            </div>

            <!-- Card 6: Publishing -->
            <div class="industry-card group relative h-[240px] md:h-[280px] rounded-xl overflow-hidden cursor-pointer">
                <img src="/services/publishing.jpg" alt="Издательство" class="absolute inset-0 w-full h-full object-cover"/>
                <div class="absolute inset-0 bg-[#006644]/70 group-hover:bg-[#006644]/55 transition-all duration-300"></div>
                <div class="relative z-10 flex flex-col justify-end h-full p-6 md:p-8">
                    <div class="mb-3">
                        <svg class="w-10 h-10 text-white/80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                    </div>
                    <h3 class="text-xl md:text-2xl font-bold text-white">Издательство</h3>
                    <p class="text-white/70 text-sm mt-2 group-hover:text-white/90 transition-colors">Редакционно-издательские системы</p>
                </div>
            </div>
        </div>

    </div>
</section>

<style>
    .industry-card {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .industry-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.15);
    }
</style>
