---
import { Image } from "astro:assets";
import Title from "./Title.astro";
import Subtitle from "./Subtitle.astro";
import aboutUsDecor from "../assets/about-us-decor.png";
import aboutUsTextDecor from "../assets/about-us-text-decor.svg";
---

<section id="about" class="py-16 md:py-24 bg-white">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-8">
        <!-- Section intro -->
        <div class="text-center max-w-2xl mx-auto mb-16 about-us-content">
            <div class="flex items-center justify-center gap-3 mb-5">
                <div class="w-8 h-0.5 bg-[var(--blue)]"></div>
                <span class="text-sm font-semibold text-[var(--blue)] uppercase tracking-widest">О компании</span>
                <div class="w-8 h-0.5 bg-[var(--blue)]"></div>
            </div>
            <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-[var(--navy)] leading-tight mb-4">
                Мы создаём технологии,<br/>
                <span class="text-[var(--blue)]">меняющие будущее</span>
            </h2>
            <p class="text-[var(--text-secondary)] text-base md:text-lg leading-relaxed">
                Разрабатываем инновационные IT-решения для бизнеса и государственных структур — от мобильных приложений до AI и VR технологий.
            </p>
        </div>


        <!-- 2-Column card grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
            <!-- Card 1: VR/AR -->
            <div class="about-card group bg-white rounded-xl shadow-lg hover:shadow-xl border border-gray-100 overflow-hidden transition-all duration-300">
                <div class="relative h-[220px] md:h-[260px] overflow-hidden">
                    <img 
                        src="/about/vr-ar.jpg" 
                        alt="VR/AR технологии"
                        class="about-us-decor w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
                </div>
                <div class="p-8 md:p-10">
                    <h3 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">
                        VR & AR Решения<span class="text-[#0052CC]">.</span>
                    </h3>
                    <p class="text-base md:text-lg text-gray-600 leading-relaxed mb-6">
                        Наши эксперты разрабатывают приложения для разных сфер: от мобильных и веб-приложений до решений, использующих передовые VR и AR технологии.
                    </p>
                    <a href="#portfolio" class="inline-flex items-center font-semibold text-[#0052CC] hover:text-[#4C9AFF] transition-colors group/link">
                        <span class="mr-1 text-lg">▸</span>
                        <span>Узнать больше</span>
                    </a>
                </div>
            </div>

            <!-- Card 2: AI & Software -->
            <div class="about-card group bg-white rounded-xl shadow-lg hover:shadow-xl border border-gray-100 overflow-hidden transition-all duration-300">
                <div class="relative h-[220px] md:h-[260px] overflow-hidden">
                    <img 
                        src="/about/ai-dev.jpg" 
                        alt="AI и разработка ПО"
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
                </div>
                <div class="p-8 md:p-10">
                    <h3 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">
                        AI & Разработка ПО<span class="text-[#0052CC]">.</span>
                    </h3>
                    <p class="text-base md:text-lg text-gray-600 leading-relaxed mb-6">
                        Мы интегрируем искусственный интеллект в различные процессы, помогая бизнесам улучшать взаимодействие с клиентами, обучать сотрудников и создавать уникальные пользовательские интерфейсы.
                    </p>
                    <a href="/solutions/ris" class="inline-flex items-center font-semibold text-[#0052CC] hover:text-[#4C9AFF] transition-colors group/link">
                        <span class="mr-1 text-lg">▸</span>
                        <span>Узнать больше</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .about-card {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .about-card:hover {
        transform: translateY(-6px);
    }
</style>
