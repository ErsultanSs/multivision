---
import { Image } from "astro:assets";
import image1 from "../assets/image1.jpg";
---

<section class="quick-facts bg-white py-16 md:py-24">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-0 items-stretch">
            <!-- Left: description text -->
            <div class="flex flex-col justify-center p-8 lg:p-12 bg-gray-50 rounded-l-2xl lg:rounded-l-2xl rounded-t-2xl lg:rounded-tr-none">
                <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4 leading-tight">
                    Надежный партнер в IT-решениях
                </h2>
                <p class="text-base md:text-lg text-gray-600 leading-relaxed mb-6">
                    Мы помогаем организациям трансформировать бизнес с помощью передовых технологий. 
                    От AI-решений до VR/AR — наша команда воплощает самые амбициозные идеи в реальность.
                </p>
                <a href="#about" class="inline-flex items-center text-[#0052CC] font-semibold hover:text-[#4C9AFF] transition-colors group">
                    <span>Подробнее о нас</span>
                    <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                </a>
            </div>

            <!-- Center: image -->
            <div class="relative overflow-hidden">
                <Image 
                    src={image1} 
                    alt="Команда Multivision"
                    class="w-full h-full object-cover min-h-[300px] lg:min-h-full"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-[#0052CC]/10 to-transparent"></div>
            </div>

            <!-- Right: stats numbers -->
            <div class="flex flex-col justify-center bg-gray-50 rounded-r-2xl lg:rounded-r-2xl rounded-b-2xl lg:rounded-bl-none p-8 lg:p-12">
                <div class="space-y-10">
                    <div class="fact-item">
                        <div class="flex items-baseline gap-1">
                            <span class="text-[48px] md:text-[56px] font-bold text-gray-900 leading-none">10</span>
                            <span class="text-[48px] md:text-[56px] font-bold text-[#0052CC] leading-none">+</span>
                        </div>
                        <p class="text-base text-gray-600 mt-2 font-medium">Лет успешного опыта</p>
                    </div>
                    <div class="fact-item">
                        <div class="flex items-baseline gap-1">
                            <span class="text-[48px] md:text-[56px] font-bold text-gray-900 leading-none">50</span>
                            <span class="text-[48px] md:text-[56px] font-bold text-[#0052CC] leading-none">+</span>
                        </div>
                        <p class="text-base text-gray-600 mt-2 font-medium">Реализованных проектов</p>
                    </div>
                    <div class="fact-item">
                        <div class="flex items-baseline gap-1">
                            <span class="text-[48px] md:text-[56px] font-bold text-gray-900 leading-none">100</span>
                            <span class="text-[48px] md:text-[56px] font-bold text-[#0052CC] leading-none">+</span>
                        </div>
                        <p class="text-base text-gray-600 mt-2 font-medium">Довольных клиентов</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .fact-item {
        transition: transform 0.3s ease;
    }
    .fact-item:hover {
        transform: translateX(8px);
    }
</style>
