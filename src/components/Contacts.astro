---
import { Image } from "astro:assets";
import locationIcon from "../assets/location-icon.svg";
import phoneIcon from "../assets/phone-icon.svg";
import messageIcon from "../assets/message-icon.svg";
---

<div id="contacts" class="flex flex-col items-center justify-center px-[10px] lg:px-12 py-[56px] lg:py-[84px] z-30 contact-section bg-white">
    <h6 class="font-bold text-center text-wrap text-3xl sm:text-5xl lg:text-6xl leading-tight text-gray-900 mb-12">
        Наши контактные данные    
    </h6>

    <div class="flex flex-col lg:flex-row justify-center gap-8 lg:gap-12">
        <div class="flex flex-row items-center gap-4 p-6 bg-gray-50 rounded-xl hover:bg-blue-50 hover:shadow-md transition-all duration-300">
            <div class="p-5 bg-gradient-to-r from-[#0052CC] to-[#4C9AFF] rounded-full transition-transform duration-300 hover:scale-110">
                <Image src={locationIcon} alt="Иконка местоположения"/>
            </div>
            <p class="w-[290px] text-base md:text-lg leading-relaxed text-gray-700 font-medium">Алматы, улица Кенесары хана, 54/19</p>
        </div>
        <div class="flex flex-row items-center gap-4 p-6 bg-gray-50 rounded-xl hover:bg-blue-50 hover:shadow-md transition-all duration-300 cursor-pointer" data-phone>
            <div class="p-5 bg-gradient-to-r from-[#0052CC] to-[#4C9AFF] rounded-full transition-transform duration-300 hover:scale-110">
                <Image src={phoneIcon} alt="Иконка телефона"/>
            </div>
            <p class="text-base md:text-lg leading-relaxed text-gray-700 font-medium">+7 777 007 0709</p>
        </div>
        <div class="flex flex-row items-center gap-4 p-6 bg-gray-50 rounded-xl hover:bg-blue-50 hover:shadow-md transition-all duration-300 cursor-pointer" data-email>
            <div class="p-5 bg-gradient-to-r from-[#0052CC] to-[#4C9AFF] rounded-full transition-transform duration-300 hover:scale-110">
                <Image src={messageIcon} alt="Иконка сообщения"/>
            </div>
            <p class="text-base md:text-lg leading-relaxed text-gray-700 font-medium">llcmultivision@gmail.com</p>
        </div>
    </div>
</div>

<script>
    document.querySelector('[data-phone]')?.addEventListener('click', () => {
        window.location.href = 'tel:+77770070709';
    });
    
    document.querySelector('[data-email]')?.addEventListener('click', () => {
        window.location.href = 'mailto:llcmultivision@gmail.com';
    });
</script>
